# =============================================================
# Docker 실행용 환경변수 템플릿
# 사용: 이 파일을 .env.docker로 복사한 뒤 값 채우기
# git 제외 대상 (.gitignore의 .env* 포함)
# =============================================================

# ---- Django ----
SECRET_KEY=change-me-to-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---- PostgreSQL (docker-compose 내부 통신) ----
# 단계 1 로컬 검증에서는 기본값 그대로 사용 가능.
# 단계 2~6 naxer-main 배포 시 운영 비밀번호로 교체.
POSTGRES_DB=tshirt_management
POSTGRES_USER=tshirt_admin
POSTGRES_PASSWORD=tshirt_local_pass

# DATABASE_URL은 docker-compose.yml의 environment에서 자동 조합됨.
# 직접 지정하려면 아래 주석 해제 (compose 환경변수보다 우선)
# DATABASE_URL=postgresql://tshirt_admin:tshirt_local_pass@db:5432/tshirt_management

# ---- 외부 API (단계 1 로컬 검증에선 빈 값 OK, 단계 3에서 Render 백업으로 채움) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

GOOGLE_DRIVE_CREDENTIALS_PATH=
GOOGLE_DRIVE_PARENT_FOLDER_ID=
# GOOGLE_OAUTH_TOKEN_BASE64=

# ---- Popbill (단계 0 결정: 폐기, 데이터만 5년 보관) ----
POPBILL_LINK_ID=TESTER
POPBILL_IS_TEST=True
POPBILL_CORP_NUM=
POPBILL_BANK_CODE=
POPBILL_ACCOUNT_NUMBER=
# POPBILL_SECRET_KEY=  # 운영 키는 .env.docker에만, 본 파일엔 비움
